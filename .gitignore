# ── Launcher — build artifacts ────────────────────────────────────────────────
BigEd/launcher/dist/
BigEd/launcher/build/

# ── Launcher — PyInstaller spec files (contain absolute paths, regenerated) ───
BigEd/launcher/*.spec

# ── Launcher — CRM / tools SQLite database (user runtime data) ───────────────
BigEd/launcher/data/

# ── Claude Code local settings (permissions, not project instructions) ────────
.claude/
!.claude/skills/**

# ── Local machine config (personal hardware/env/MCP — never committed) ────────
.mcp.json
push.sh

# ── Fleet — runtime files (regenerated every run) ────────────────────────────
fleet/.drders_heartbeat
fleet/.supervisor_heartbeat
fleet/.cost_anomaly_throttle
fleet/knowledge/screenshots/

# ── Launcher — runtime data (boot timing, caches) ────────────────────────────
BigEd/launcher/ui/data/

# ── Docker (local dev orchestration) ─────────────────────────────────────────
docker-compose.yml

# ── MCP context mirror (copies of root .md files for container access) ───────
education-context/

# ── Fleet runtime state ──────────────────────────────────────────────────
fleet/hw_state.json
fleet/_graveyard/
fleet/knowledge/evolution/
fleet/knowledge/marathon/
fleet/knowledge/swarm/
fleet/knowledge/consensus/
fleet/knowledge/datasets/
fleet/knowledge/ml_results/
