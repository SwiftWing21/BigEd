fleet/data/

# ── IDE — MCP config (may contain credentials; launch.json + tasks.json stay tracked)
.vscode/mcp.json

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
