# ── Secrets / credentials ─────────────────────────────────────────────────────
.env
.env.*
.secrets
*.secrets
secrets.*

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Documentation — private by default, whitelist product files ──────────────
*.md
!README.md
!CONTRIBUTING.md
!SETUP.md
!autoresearch/README.md
!.github/PULL_REQUEST_TEMPLATE.md
!docs/flowcharts/README.md
!docs/screenshots/README.md
!.claude/skills/**/*.md
!fleet/templates/**/*.md

# ── Fleet — runtime databases ─────────────────────────────────────────────────
fleet/fleet.db
fleet/fleet.db-shm
fleet/fleet.db-wal
fleet/rag.db
fleet/rag.db-shm
fleet/rag.db-wal

# ── Fleet — ephemeral HITL response files ─────────────────────────────────────
fleet/hitl-responses/

# ── Launcher — single-instance lock ───────────────────────────────────────────
BigEd/launcher/data/biged.lock

# ── Fleet — misplaced VS Code configs (Gemini artifacts) ─────────────────────
fleet/launch.json
fleet/tasks.json
fleet/skills/launch.json
fleet/skills/tasks.json

# ── Fleet — TLS certs (auto-generated, never commit) ─────────────────────────
fleet/certs/

# ── Fleet — logs ──────────────────────────────────────────────────────────────
fleet/logs/*
!fleet/logs/.gitkeep

# ── Fleet — generated knowledge (runtime output, not source) ──────────────────
fleet/knowledge/leads/
fleet/knowledge/reports/
fleet/knowledge/summaries/
fleet/knowledge/discussion/
fleet/knowledge/code_discussion/
fleet/knowledge/security/
fleet/knowledge/marketing/
